# AI_RFIC_workflow environment template
#
# This repository does not automatically load .env files by itself.
# Use this file as a reference template for:
# - manual PowerShell export
# - IDE run configurations
# - direnv or similar tooling
# - your own wrapper scripts

# ADS worker entry interpreter
ADS_PYTHON=C:\Path\To\ADS\tools\python\python.exe

# ADS installation root
ADS_INSTALL_DIR=C:\Path\To\ADS

# Optional: main PDK library directory
PDK_DIR=C:\Path\To\PDK

# Optional: technology/reference library directory paired with the PDK
PDK_TECH_DIR=C:\Path\To\PDK_Tech

# Optional: substrate definition name from the selected PDK/reference library
SUBSTRATE=your_substrate_name

# Optional: if you maintain a separate ML environment, record it here for your own tooling
# ML_PYTHON=C:\Path\To\python.exe
